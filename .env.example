# ─── Required ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# PostgreSQL connection string (matches docker-compose defaults)
DATABASE_URL=postgresql://user:password@localhost:5432/recovery_db

# ─── Production ───────────────────────────────────────────────
# FLASK_ENV=production
# FLASK_DEBUG=0

# ─── Database credentials (used by docker-compose) ───────────
# DB_USER=user
# DB_PASSWORD=<generate-a-strong-password>
# DB_NAME=recovery_db

# ─── Rate limiter (optional: default is in-memory) ───────────
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0